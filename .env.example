# Railway PostgreSQL Database
DATABASE_URL=postgresql://user:password@hostname:port/database

# Redis for circuit breaker and caching
REDIS_URL=redis://default:password@hostname:port
REDIS_HOST=hostname
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=0

# Kafka (using local Docker or managed service)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Auto-Optimization Settings
AUTO_OPTIMIZE_ENABLED=true
AUTO_OPTIMIZE_THRESHOLD_PCT=5.0
AUTO_OPTIMIZE_INTERVAL_MIN=5
SHADOW_TESTING_WINDOW_MIN=60

# Spark Configuration
SPARK_MASTER=local

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-change-this

# Copy Bot
COPY_MODE=shadow              # shadow | live | off
COPY_MAX_TRADE_PCT=0.10       # max 10% of wallet per copied trade
COPY_TOP_N=5                  # number of top wallets to copy
COPY_TOP_PCT=0.10             # top 10% by composite score enter copy list
